# Databas-URL från Neon.tech (postgresql://...)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Slumpmässig hemlig nyckel – generera med: openssl rand -base64 32
NEXTAUTH_SECRET="byt-ut-detta-till-en-riktig-hemlig-nyckel"

# Din apps URL på Vercel (utan snedstreck i slutet)
NEXTAUTH_URL="https://din-app.vercel.app"

# Admin-konto som skapas vid första db:setup
ADMIN_EMAIL="din@epost.se"
ADMIN_PASSWORD="välj-ett-starkt-lösenord"
ADMIN_NAME="Ditt Namn"
